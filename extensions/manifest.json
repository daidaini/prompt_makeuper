{
  "manifest_version": 3,
  "name": "Prompt Makeuper",
  "version": "1.0.0",
  "description": "Optimize your prompts using AI-powered skill selection and refinement",
  "api_base_url": "http://localhost:8000",
  "permissions": [
    "activeTab",
    "sidePanel",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "images/logo-16.png",
      "32": "images/logo-32.png",
      "48": "images/logo-48.png",
      "128": "images/logo-128.png"
    }
  },
  "icons": {
    "16": "images/logo-16.png",
    "48": "images/logo-48.png",
    "128": "images/logo-128.png"
  }
}
